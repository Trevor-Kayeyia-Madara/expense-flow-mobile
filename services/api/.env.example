PORT=4000
HOST=0.0.0.0
# Comma-separated allowed origins for CORS (use "*" for dev if needed)
ORIGIN=http://localhost:5173

JWT_SECRET=dev-secret-change-me-please-change

# Public base URL used to generate approval links (use your LAN IP for phone testing)
PUBLIC_BASE_URL=http://192.168.100.7:4000

# SMTP (Gmail test: use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=techsavvy826@gmail.com
SMTP_PASS=Tech.26@24
SMTP_FROM="ExpenseFlow techsavvy826@gmail.com"

# PostgreSQL (prefer DATABASE_URL in cloud)
# Example: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USER=expenseflow
DB_PASSWORD=expenseflow
DB_NAME=expenseflow
DB_SSL=false

# Uploads (local dev). In production use object storage (S3/Blob) behind a CDN.
UPLOAD_DIR=./uploads

# Seed a first tenant + admin user (for local dev)
SEED_TENANT_NAME=Demo Company
SEED_ADMIN_EMAIL=admin@demo.local
SEED_ADMIN_PASSWORD=admin1234
